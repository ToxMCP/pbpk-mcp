{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ReverseDosimetryRecord.v1.schema.json",
  "title": "ReverseDosimetryRecord.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "reverseDosimetryRecordId",
    "podRef",
    "internalExposureRef",
    "method",
    "outputDose",
    "route",
    "timeBasis",
    "basisConversionRefs",
    "applicabilityBoundaryRefs",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "qualificationStatus",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "limitations",
    "notARiskConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ReverseDosimetryRecord.v1.schema.json"
    },
    "reverseDosimetryRecordId": {
      "type": "string",
      "minLength": 1
    },
    "podRef": {
      "type": "string",
      "minLength": 1
    },
    "internalExposureRef": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "enum": [
        "analytic_css",
        "pbk_reverse_dosimetry",
        "httk_screening",
        "biomonitoring_inference",
        "not_assessed"
      ]
    },
    "outputDose": {
      "$ref": "https://schemas.ngra.ai/toxmcp/MeasurementValue.v1.schema.json"
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "aggregate",
        "not_assessed"
      ]
    },
    "timeBasis": {
      "type": "string",
      "minLength": 1
    },
    "basisConversionRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicabilityBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "qualificationStatus": {
      "enum": [
        "screening",
        "fit_for_context_with_limitations",
        "review_required",
        "blocked",
        "not_assessed"
      ]
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notARiskConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
