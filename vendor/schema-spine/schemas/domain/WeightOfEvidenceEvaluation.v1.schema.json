{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/WeightOfEvidenceEvaluation.v1.schema.json",
  "title": "WeightOfEvidenceEvaluation.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "woeEvaluationId",
    "decisionContextRef",
    "problemFormulation",
    "evidenceRefs",
    "integrationMethod",
    "evidenceDependenceAssessment",
    "conflictStatus",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "conclusionClaimClass",
    "conclusionSupportLevel",
    "actionability",
    "reviewState",
    "limitations",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/WeightOfEvidenceEvaluation.v1.schema.json"
    },
    "woeEvaluationId": {
      "type": "string",
      "minLength": 1
    },
    "decisionContextRef": {
      "type": "string",
      "minLength": 1
    },
    "problemFormulation": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integrationMethod": {
      "enum": [
        "structured_expert_judgment",
        "predefined_decision_rule",
        "bayesian_weighting",
        "narrative_synthesis",
        "numeric_score_only",
        "not_assessed"
      ]
    },
    "evidenceDependenceAssessment": {
      "enum": [
        "independent",
        "partially_dependent",
        "dependent",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "conflictStatus": {
      "enum": [
        "no_material_conflict",
        "conflict_resolved",
        "unresolved_conflict",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conclusionClaimClass": {
      "enum": [
        "identity",
        "context_only",
        "association",
        "bioactivity",
        "mechanistic_support",
        "causal_support",
        "adversity",
        "exposure",
        "internal_dose",
        "risk",
        "regulatory_translation",
        "not_assessed"
      ]
    },
    "conclusionSupportLevel": {
      "enum": [
        "not_assessed",
        "context_only",
        "weak",
        "moderate",
        "strong",
        "conflicting",
        "insufficient",
        "unknown_with_blocker"
      ]
    },
    "actionability": {
      "enum": [
        "none",
        "screening",
        "prioritization",
        "requires_review",
        "decision_support",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "reviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
