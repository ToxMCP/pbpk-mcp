{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ValidationEvidenceBundle.v1.schema.json",
  "title": "ValidationEvidenceBundle.v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "refList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "nonEmptyRefList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  },
  "required": [
    "schemaId",
    "validationEvidenceBundleId",
    "targetMcpRef",
    "benchmarkRunResultRefs",
    "externalCorpusRefs",
    "artifactRefs",
    "rawInputOutputRetention",
    "integrityStatus",
    "reproducibilityStatus",
    "modelUseRefs",
    "humanReviewRefs",
    "licenseClearance",
    "dataRightsClearance",
    "evidenceStatus",
    "limitations",
    "notRegulatoryAcceptance"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ValidationEvidenceBundle.v1.schema.json"
    },
    "validationEvidenceBundleId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "targetMcpRef": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "benchmarkRunResultRefs": {
      "$ref": "#/$defs/nonEmptyRefList"
    },
    "externalCorpusRefs": {
      "$ref": "#/$defs/refList"
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactId",
          "artifactType",
          "uri",
          "digest",
          "retentionPolicy"
        ],
        "properties": {
          "artifactId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "artifactType": {
            "enum": [
              "json",
              "markdown",
              "log",
              "trace",
              "report",
              "dataset",
              "other"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "digest": {
            "$ref": "#/$defs/digest"
          },
          "retentionPolicy": {
            "enum": [
              "retained",
              "redacted_with_digest",
              "not_retained_with_reason",
              "not_assessed"
            ]
          }
        }
      }
    },
    "rawInputOutputRetention": {
      "enum": [
        "retained",
        "redacted_with_digest",
        "not_retained_with_reason",
        "not_assessed"
      ]
    },
    "integrityStatus": {
      "enum": [
        "verified",
        "partial",
        "failed",
        "not_assessed"
      ]
    },
    "reproducibilityStatus": {
      "enum": [
        "reproducible",
        "partially_reproducible",
        "not_reproducible",
        "unknown_with_blocker"
      ]
    },
    "modelUseRefs": {
      "$ref": "#/$defs/refList"
    },
    "humanReviewRefs": {
      "$ref": "#/$defs/refList"
    },
    "licenseClearance": {
      "enum": [
        "cleared",
        "restricted",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "dataRightsClearance": {
      "enum": [
        "cleared",
        "restricted",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "evidenceStatus": {
      "enum": [
        "complete",
        "partial",
        "blocked",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "notRegulatoryAcceptance": {
      "type": "boolean",
      "const": true
    }
  }
}
