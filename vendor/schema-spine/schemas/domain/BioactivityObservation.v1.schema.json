{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/BioactivityObservation.v1.schema.json",
  "title": "BioactivityObservation.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "bioactivityObservationId",
    "chemicalRef",
    "assayId",
    "assayName",
    "methodStandardRefs",
    "endpoint",
    "biologicalContext",
    "concentrationAxis",
    "responseMetric",
    "replicateSummary",
    "controls",
    "qualityFlags",
    "batchEffectAssessment",
    "cytotoxicityConfounding",
    "fitReadiness",
    "applicabilityBoundaryRefs",
    "limitations",
    "notAnAdversityConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/BioactivityObservation.v1.schema.json"
    },
    "bioactivityObservationId": {
      "type": "string",
      "minLength": 1
    },
    "chemicalRef": {
      "type": "string",
      "minLength": 1
    },
    "assayId": {
      "type": "string",
      "minLength": 1
    },
    "assayName": {
      "type": "string",
      "minLength": 1
    },
    "methodStandardRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "biologicalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["species", "modelSystem", "tissueOrCellType", "exposureDuration"],
      "properties": {
        "species": {
          "type": "string",
          "minLength": 1
        },
        "modelSystem": {
          "type": "string",
          "minLength": 1
        },
        "tissueOrCellType": {
          "type": "string",
          "minLength": 1
        },
        "exposureDuration": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "concentrationAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["concentrationUnit", "concentrationLevels", "minConcentration", "maxConcentration", "spacing"],
      "properties": {
        "concentrationUnit": {
          "type": "string",
          "minLength": 1
        },
        "concentrationLevels": {
          "type": "integer",
          "minimum": 1
        },
        "minConcentration": {
          "$ref": "https://schemas.ngra.ai/toxmcp/MeasurementValue.v1.schema.json"
        },
        "maxConcentration": {
          "$ref": "https://schemas.ngra.ai/toxmcp/MeasurementValue.v1.schema.json"
        },
        "spacing": {
          "enum": [
            "log",
            "linear",
            "irregular",
            "single_concentration",
            "not_assessed"
          ]
        }
      }
    },
    "responseMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "unit", "effectDirection"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "effectDirection": {
          "enum": [
            "increase",
            "decrease",
            "bidirectional",
            "not_assessed"
          ]
        }
      }
    },
    "replicateSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["biologicalReplicates", "technicalReplicates", "plateOrBatchCount"],
      "properties": {
        "biologicalReplicates": {
          "type": "integer",
          "minimum": 0
        },
        "technicalReplicates": {
          "type": "integer",
          "minimum": 0
        },
        "plateOrBatchCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vehicle", "negative", "positive"],
      "properties": {
        "vehicle": {
          "enum": ["valid", "missing", "failed", "not_applicable"]
        },
        "negative": {
          "enum": ["valid", "missing", "failed", "not_applicable"]
        },
        "positive": {
          "enum": ["valid", "missing", "failed", "not_applicable"]
        }
      }
    },
    "qualityFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "batchEffectAssessment": {
      "enum": [
        "not_detected",
        "resolved",
        "unresolved",
        "not_assessed"
      ]
    },
    "cytotoxicityConfounding": {
      "enum": [
        "ruled_out",
        "possible",
        "likely",
        "not_assessed"
      ]
    },
    "fitReadiness": {
      "enum": [
        "pod_ready",
        "screening_only",
        "context_only",
        "blocked",
        "not_assessed"
      ]
    },
    "applicabilityBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notAnAdversityConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
