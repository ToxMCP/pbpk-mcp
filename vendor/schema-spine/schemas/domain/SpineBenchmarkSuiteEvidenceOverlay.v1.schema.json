{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SpineBenchmarkSuiteEvidenceOverlay.v1.schema.json",
  "title": "SpineBenchmarkSuiteEvidenceOverlay.v1",
  "description": "Spine EVIDENCE OVERLAY over a Hub-owned benchmark suite/report. Does NOT restate the Hub's benchmark cases, metrics, or thresholds (those live in the referenced Hub artifact); references the Hub artifact by id+digest and adds only the net-new scientific layer (which anti-overclaim/scientific invariants the suite covers, release-blocking governance, non-claim guard). See docs/adr/0001-spine-hub-reconciliation.md.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "nonEmptyRefList": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } }
  },
  "required": [
    "schemaId",
    "overlayId",
    "mcpId",
    "hubArtifactRef",
    "hubSchemaId",
    "hubSchemaVersion",
    "hubArtifactDigest",
    "benchmarkFamily",
    "scientificInvariantRefs",
    "releaseBlocking",
    "limitations",
    "notScientificValidation"
  ],
  "properties": {
    "schemaId": { "const": "https://schemas.ngra.ai/toxmcp/SpineBenchmarkSuiteEvidenceOverlay.v1.schema.json" },
    "overlayId": { "$ref": "#/$defs/nonEmptyString" },
    "mcpId": { "type": "string", "pattern": "^toxmcp\\.[a-z0-9][a-z0-9-]*\\.[a-z0-9][a-z0-9-]*$" },
    "hubArtifactRef": { "$ref": "#/$defs/nonEmptyString" },
    "hubSchemaId": { "type": "string", "format": "uri", "minLength": 1 },
    "hubSchemaVersion": { "$ref": "#/$defs/nonEmptyString" },
    "hubArtifactDigest": { "$ref": "#/$defs/digest" },
    "benchmarkFamily": { "enum": ["smoke", "ngra_core", "transport_conformance", "scientific_invariants", "security_release", "external_validation", "regression", "integration"] },
    "scientificInvariantRefs": { "$ref": "#/$defs/nonEmptyRefList" },
    "releaseBlocking": { "type": "boolean" },
    "limitations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
    "notScientificValidation": { "type": "boolean", "const": true }
  }
}
