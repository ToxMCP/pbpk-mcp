{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/IataStrategyDecision.v1.schema.json",
  "title": "IataStrategyDecision.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "iataStrategyDecisionId",
    "decisionContextRef",
    "regulatoryScenario",
    "problemFormulation",
    "evidenceBundleRefs",
    "remainingUncertainties",
    "testingOptions",
    "stoppingRules",
    "proportionalityRationale",
    "selectedOption",
    "reviewState",
    "strategyStatus",
    "limitations",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/IataStrategyDecision.v1.schema.json"
    },
    "iataStrategyDecisionId": {
      "type": "string",
      "minLength": 1
    },
    "decisionContextRef": {
      "type": "string",
      "minLength": 1
    },
    "regulatoryScenario": {
      "type": "string",
      "minLength": 1
    },
    "problemFormulation": {
      "type": "string",
      "minLength": 1
    },
    "evidenceBundleRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remainingUncertainties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "testingOptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["optionId", "purpose", "addressesUncertaintyRefs", "expectedInformationGain", "burdenClass", "prerequisiteRefs"],
        "properties": {
          "optionId": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "addressesUncertaintyRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expectedInformationGain": {
            "enum": [
              "low",
              "moderate",
              "high",
              "not_assessed"
            ]
          },
          "burdenClass": {
            "enum": [
              "non_animal",
              "low_burden",
              "moderate_burden",
              "high_burden",
              "not_assessed"
            ]
          },
          "prerequisiteRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "stoppingRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proportionalityRationale": {
      "type": "string",
      "minLength": 1
    },
    "selectedOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optionId", "selectionRationale"],
      "properties": {
        "optionId": {
          "type": "string",
          "minLength": 1
        },
        "selectionRationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "strategyStatus": {
      "enum": [
        "draft",
        "review_required",
        "selected_for_review",
        "final_strategy",
        "blocked",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
