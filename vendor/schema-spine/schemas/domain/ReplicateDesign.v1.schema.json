{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ReplicateDesign.v1.schema.json",
  "title": "ReplicateDesign.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "replicateDesignId",
    "studyRef",
    "biologicalUnit",
    "technicalUnit",
    "biologicalReplicateCount",
    "technicalReplicateCount",
    "nestingStructure",
    "pseudoreplicationRisk",
    "supportInflationProhibited",
    "limitations"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ReplicateDesign.v1.schema.json"
    },
    "replicateDesignId": {
      "type": "string",
      "minLength": 1
    },
    "studyRef": {
      "type": "string",
      "minLength": 1
    },
    "biologicalUnit": {
      "type": "string",
      "minLength": 1
    },
    "technicalUnit": {
      "type": "string",
      "minLength": 1
    },
    "biologicalReplicateCount": {
      "type": "integer",
      "minimum": 0
    },
    "technicalReplicateCount": {
      "type": "integer",
      "minimum": 0
    },
    "nestingStructure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pseudoreplicationRisk": {
      "enum": [
        "ruled_out",
        "possible",
        "likely",
        "not_assessed"
      ]
    },
    "supportInflationProhibited": {
      "type": "boolean",
      "const": true
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
