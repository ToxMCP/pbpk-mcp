{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SubgroupReviewPacket.v1.schema.json",
  "title": "SubgroupReviewPacket.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "subgroupReviewPacketId",
    "populationProfileRefs",
    "subgroupDefinitionRefs",
    "sensitiveDescriptorPolicyRefs",
    "variabilityDimensionRefs",
    "modifierEvidenceLaneRefs",
    "comparisonRefs",
    "susceptibilitySummaryRefs",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "nonClaimBoundaryRefs",
    "reviewStatus",
    "handoffEligibility",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "limitations",
    "notIndividualRiskPrediction",
    "notFinalRiskConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/SubgroupReviewPacket.v1.schema.json"
    },
    "subgroupReviewPacketId": {
      "type": "string",
      "minLength": 1
    },
    "populationProfileRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "subgroupDefinitionRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sensitiveDescriptorPolicyRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "variabilityDimensionRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "modifierEvidenceLaneRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "comparisonRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "susceptibilitySummaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "nonClaimBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewStatus": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "handoffEligibility": {
      "enum": [
        "blocked",
        "review_required",
        "eligible_with_limitations",
        "not_assessed"
      ]
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "notIndividualRiskPrediction": {
      "type": "boolean",
      "const": true
    },
    "notFinalRiskConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
