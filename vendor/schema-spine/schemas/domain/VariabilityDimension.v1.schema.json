{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/VariabilityDimension.v1.schema.json",
  "title": "VariabilityDimension.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "variabilityDimensionId",
    "subgroupRef",
    "dimensionType",
    "direction",
    "modifierMetric",
    "evidenceLaneRefs",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "actionability",
    "limitations"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/VariabilityDimension.v1.schema.json"
    },
    "variabilityDimensionId": {
      "type": "string",
      "minLength": 1
    },
    "subgroupRef": {
      "type": "string",
      "minLength": 1
    },
    "dimensionType": {
      "enum": [
        "exposure",
        "tk",
        "td",
        "disease_or_organ_impairment",
        "genetic",
        "behavior_use_pattern",
        "lifestage",
        "biomonitoring",
        "extrinsic",
        "sensitive_descriptor",
        "not_assessed"
      ]
    },
    "direction": {
      "enum": [
        "higher_susceptibility",
        "lower_susceptibility",
        "ambiguous",
        "not_assessed"
      ]
    },
    "modifierMetric": {
      "type": "string",
      "minLength": 1
    },
    "evidenceLaneRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actionability": {
      "enum": [
        "none",
        "screening",
        "prioritization",
        "requires_review",
        "decision_support",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
