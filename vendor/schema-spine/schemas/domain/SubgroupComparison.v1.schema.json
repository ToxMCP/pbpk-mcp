{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SubgroupComparison.v1.schema.json",
  "title": "SubgroupComparison.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "subgroupComparisonId",
    "subgroupRef",
    "referencePopulationRef",
    "comparatorPopulationRef",
    "comparisonBasis",
    "endpointOrModifier",
    "effectDirection",
    "effectMagnitudeBand",
    "comparatorConsistency",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "limitations",
    "notIndividualRiskPrediction",
    "notRiskConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/SubgroupComparison.v1.schema.json"
    },
    "subgroupComparisonId": {
      "type": "string",
      "minLength": 1
    },
    "subgroupRef": {
      "type": "string",
      "minLength": 1
    },
    "referencePopulationRef": {
      "type": "string",
      "minLength": 1
    },
    "comparatorPopulationRef": {
      "type": "string",
      "minLength": 1
    },
    "comparisonBasis": {
      "enum": [
        "same_population_reference",
        "external_population_reference",
        "modelled_default",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "endpointOrModifier": {
      "type": "string",
      "minLength": 1
    },
    "effectDirection": {
      "enum": [
        "higher",
        "lower",
        "ambiguous",
        "none",
        "not_assessed"
      ]
    },
    "effectMagnitudeBand": {
      "enum": [
        "none",
        "low",
        "moderate",
        "high",
        "unknown",
        "not_assessed"
      ]
    },
    "comparatorConsistency": {
      "enum": [
        "consistent",
        "partial",
        "mismatch",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notIndividualRiskPrediction": {
      "type": "boolean",
      "const": true
    },
    "notRiskConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
