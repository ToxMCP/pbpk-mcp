{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/InternalExposureSummary.v1.schema.json",
  "title": "InternalExposureSummary.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "internalExposureSummaryId",
    "sourceExposureRefs",
    "metricType",
    "metricValue",
    "bindingBasis",
    "matrix",
    "compartment",
    "route",
    "duration",
    "timeBasis",
    "population",
    "populationPercentile",
    "pbkTier",
    "modelId",
    "modelVersion",
    "modelQualificationStatus",
    "parameterProvenanceRefs",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "limitations",
    "notARiskConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/InternalExposureSummary.v1.schema.json"
    },
    "internalExposureSummaryId": {
      "type": "string",
      "minLength": 1
    },
    "sourceExposureRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metricType": {
      "enum": [
        "css",
        "cmax",
        "auc",
        "average_concentration",
        "internal_dose_rate",
        "not_assessed"
      ]
    },
    "metricValue": {
      "$ref": "https://schemas.ngra.ai/toxmcp/MeasurementValue.v1.schema.json"
    },
    "bindingBasis": {
      "enum": [
        "total",
        "free",
        "unbound",
        "nominal",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "matrix": {
      "enum": [
        "plasma",
        "blood",
        "serum",
        "tissue",
        "media",
        "urine",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "compartment": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "aggregate",
        "not_assessed"
      ]
    },
    "duration": {
      "type": "string",
      "minLength": 1
    },
    "timeBasis": {
      "type": "string",
      "minLength": 1
    },
    "population": {
      "type": "string",
      "minLength": 1
    },
    "populationPercentile": {
      "type": "string",
      "minLength": 1
    },
    "pbkTier": {
      "enum": [
        "httk_screening",
        "generic_pbk",
        "chemical_specific_pbk",
        "qualified_pbpk",
        "biomonitoring_inference",
        "not_assessed"
      ]
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "modelVersion": {
      "type": "string",
      "minLength": 1
    },
    "modelQualificationStatus": {
      "enum": [
        "screening",
        "fit_for_context_with_limitations",
        "externally_validated",
        "review_required",
        "blocked",
        "not_assessed"
      ]
    },
    "parameterProvenanceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notARiskConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
