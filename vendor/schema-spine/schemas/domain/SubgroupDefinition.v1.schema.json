{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SubgroupDefinition.v1.schema.json",
  "title": "SubgroupDefinition.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "subgroupDefinitionId",
    "populationProfileRef",
    "subgroupLabel",
    "inclusionCriteria",
    "exclusionCriteria",
    "descriptorBasis",
    "sensitiveDescriptorPolicyRef",
    "comparatorPopulationRef",
    "subgroupGranularity",
    "uncertaintyRefs",
    "limitations",
    "notIndividualRiskPrediction"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/SubgroupDefinition.v1.schema.json"
    },
    "subgroupDefinitionId": {
      "type": "string",
      "minLength": 1
    },
    "populationProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "subgroupLabel": {
      "type": "string",
      "minLength": 1
    },
    "inclusionCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclusionCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "descriptorBasis": {
      "enum": [
        "clinical",
        "lifestage",
        "exposure_pattern",
        "tk_td_modifier",
        "genetic_marker",
        "sensitive_descriptor",
        "mixed",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "sensitiveDescriptorPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "comparatorPopulationRef": {
      "type": "string",
      "minLength": 1
    },
    "subgroupGranularity": {
      "enum": [
        "subgroup",
        "population_segment",
        "individual",
        "not_assessed"
      ]
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notIndividualRiskPrediction": {
      "type": "boolean",
      "const": true
    }
  }
}
