{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SpineBenchmarkRunEvidenceOverlay.v1.schema.json",
  "title": "SpineBenchmarkRunEvidenceOverlay.v1",
  "description": "Spine EVIDENCE OVERLAY over a Hub-owned benchmark run. Does NOT restate the Hub's case results, pass/fail gating, or digests (those live in the referenced Hub artifact); references the Hub run by id+digest and adds only the net-new scientific layer (assessment-run/provenance join, anti-overclaim findings summary, audit-chain link, non-claim guard). See docs/adr/0001-spine-hub-reconciliation.md.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "refList": { "type": "array", "items": { "$ref": "#/$defs/nonEmptyString" } }
  },
  "required": [
    "schemaId",
    "overlayId",
    "mcpId",
    "hubArtifactRef",
    "hubSchemaId",
    "hubSchemaVersion",
    "hubArtifactDigest",
    "benchmarkSuiteOverlayRef",
    "assessmentRunRef",
    "auditEventChainRef",
    "antiOverclaimFindings",
    "waiverRefs",
    "limitations",
    "notScientificValidation"
  ],
  "properties": {
    "schemaId": { "const": "https://schemas.ngra.ai/toxmcp/SpineBenchmarkRunEvidenceOverlay.v1.schema.json" },
    "overlayId": { "$ref": "#/$defs/nonEmptyString" },
    "mcpId": { "type": "string", "pattern": "^toxmcp\\.[a-z0-9][a-z0-9-]*\\.[a-z0-9][a-z0-9-]*$" },
    "hubArtifactRef": { "$ref": "#/$defs/nonEmptyString" },
    "hubSchemaId": { "type": "string", "format": "uri", "minLength": 1 },
    "hubSchemaVersion": { "$ref": "#/$defs/nonEmptyString" },
    "hubArtifactDigest": { "$ref": "#/$defs/digest" },
    "benchmarkSuiteOverlayRef": { "$ref": "#/$defs/nonEmptyString" },
    "assessmentRunRef": { "$ref": "#/$defs/nonEmptyString" },
    "auditEventChainRef": { "$ref": "#/$defs/nonEmptyString" },
    "antiOverclaimFindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overclaimFindingCount", "blockingOverclaimCount"],
      "properties": {
        "overclaimFindingCount": { "type": "integer", "minimum": 0 },
        "blockingOverclaimCount": { "type": "integer", "minimum": 0 }
      }
    },
    "waiverRefs": { "$ref": "#/$defs/refList" },
    "limitations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmptyString" } },
    "notScientificValidation": { "type": "boolean", "const": true }
  }
}
