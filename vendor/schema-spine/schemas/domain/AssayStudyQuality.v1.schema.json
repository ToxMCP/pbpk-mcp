{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/AssayStudyQuality.v1.schema.json",
  "title": "AssayStudyQuality.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "assayStudyQualityId",
    "assayRef",
    "sopRefs",
    "controlStatus",
    "acceptanceCriteriaStatus",
    "assayInterferenceStatus",
    "normalizationStatus",
    "batchOrPlateEffectStatus",
    "deviations",
    "documentationStatus",
    "handoffEligibility",
    "limitations"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/AssayStudyQuality.v1.schema.json"
    },
    "assayStudyQualityId": {
      "type": "string",
      "minLength": 1
    },
    "assayRef": {
      "type": "string",
      "minLength": 1
    },
    "sopRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "controlStatus": {
      "enum": [
        "passed",
        "passed_with_limitations",
        "failed",
        "missing",
        "not_assessed"
      ]
    },
    "acceptanceCriteriaStatus": {
      "enum": [
        "passed",
        "passed_with_limitations",
        "failed",
        "missing",
        "not_assessed"
      ]
    },
    "assayInterferenceStatus": {
      "enum": [
        "not_detected",
        "bounded",
        "unbounded",
        "not_assessed"
      ]
    },
    "normalizationStatus": {
      "enum": [
        "documented",
        "documented_with_limitations",
        "missing",
        "not_assessed"
      ]
    },
    "batchOrPlateEffectStatus": {
      "enum": [
        "not_detected",
        "resolved",
        "unresolved",
        "not_assessed"
      ]
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentationStatus": {
      "enum": [
        "complete",
        "partial_with_limitations",
        "incomplete",
        "not_assessed"
      ]
    },
    "handoffEligibility": {
      "enum": [
        "eligible",
        "eligible_with_limitations",
        "context_only",
        "blocked",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
