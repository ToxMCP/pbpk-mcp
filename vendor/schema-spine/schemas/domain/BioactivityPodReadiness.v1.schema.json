{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/BioactivityPodReadiness.v1.schema.json",
  "title": "BioactivityPodReadiness.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "bioactivityPodReadinessId",
    "podRef",
    "bioactivityObservationRefs",
    "readinessStatus",
    "blockers",
    "requiredRecordRefs",
    "allowedConsumers",
    "applicabilityBoundaryRefs",
    "confidenceCeilingRefs",
    "requiredReviewState",
    "notAnAdversityConclusion",
    "notARiskConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/BioactivityPodReadiness.v1.schema.json"
    },
    "bioactivityPodReadinessId": {
      "type": "string",
      "minLength": 1
    },
    "podRef": {
      "type": "string",
      "minLength": 1
    },
    "bioactivityObservationRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readinessStatus": {
      "enum": [
        "eligible",
        "conditional",
        "rejected",
        "blocked",
        "not_assessed"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredRecordRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedConsumers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicabilityBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredReviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "notAnAdversityConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARiskConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
