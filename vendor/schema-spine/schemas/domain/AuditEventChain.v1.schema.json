{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/AuditEventChain.v1.schema.json",
  "title": "AuditEventChain.v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaId",
    "auditEventChainId",
    "targetRef",
    "eventCount",
    "rootHash",
    "tipHash",
    "events",
    "tamperEvidenceStatus",
    "retentionPolicy",
    "limitations"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/AuditEventChain.v1.schema.json"
    },
    "auditEventChainId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "targetRef": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "eventCount": {
      "type": "integer",
      "minimum": 1
    },
    "rootHash": {
      "$ref": "#/$defs/digest"
    },
    "tipHash": {
      "$ref": "#/$defs/digest"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "eventId",
          "eventType",
          "actorType",
          "actorRef",
          "occurredAt",
          "inputDigest",
          "outputDigest",
          "previousHash",
          "eventHash"
        ],
        "properties": {
          "eventId": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "eventType": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "actorType": {
            "enum": [
              "human",
              "ai_model",
              "deterministic_tool",
              "mcp_server",
              "ci_system"
            ]
          },
          "actorRef": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          },
          "inputDigest": {
            "$ref": "#/$defs/digest"
          },
          "outputDigest": {
            "$ref": "#/$defs/digest"
          },
          "previousHash": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "eventHash": {
            "$ref": "#/$defs/digest"
          }
        }
      }
    },
    "tamperEvidenceStatus": {
      "enum": [
        "chain_valid",
        "broken_chain",
        "unverifiable",
        "not_assessed"
      ]
    },
    "retentionPolicy": {
      "enum": [
        "retained",
        "redacted_with_digest",
        "not_retained_with_reason",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  }
}
