{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ReadAcrossJustification.v1.schema.json",
  "title": "ReadAcrossJustification.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "readAcrossJustificationId",
    "targetChemicalRef",
    "sourceAnalogRefs",
    "categoryHypothesis",
    "hypothesisType",
    "similarityBasis",
    "applicabilityBoundaryRefs",
    "uncertaintyRefs",
    "analogAdequacy",
    "endpoint",
    "route",
    "population",
    "targetClaimClass",
    "supportLevel",
    "actionability",
    "limitations",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ReadAcrossJustification.v1.schema.json"
    },
    "readAcrossJustificationId": {
      "type": "string",
      "minLength": 1
    },
    "targetChemicalRef": {
      "type": "string",
      "minLength": 1
    },
    "sourceAnalogRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "categoryHypothesis": {
      "type": "string",
      "minLength": 1
    },
    "hypothesisType": {
      "enum": [
        "structural_similarity_only",
        "mechanistic",
        "metabolic",
        "empirical_category",
        "mixed",
        "not_assessed"
      ]
    },
    "similarityBasis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicabilityBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "analogAdequacy": {
      "enum": [
        "adequate_with_limitations",
        "inadequate",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "in_vitro",
        "aggregate",
        "not_applicable",
        "not_assessed"
      ]
    },
    "population": {
      "type": "string",
      "minLength": 1
    },
    "targetClaimClass": {
      "enum": [
        "identity",
        "context_only",
        "association",
        "bioactivity",
        "mechanistic_support",
        "causal_support",
        "adversity",
        "exposure",
        "internal_dose",
        "risk",
        "regulatory_translation",
        "not_assessed"
      ]
    },
    "supportLevel": {
      "enum": [
        "not_assessed",
        "context_only",
        "weak",
        "moderate",
        "strong",
        "conflicting",
        "insufficient",
        "unknown_with_blocker"
      ]
    },
    "actionability": {
      "enum": [
        "none",
        "screening",
        "prioritization",
        "requires_review",
        "decision_support",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
