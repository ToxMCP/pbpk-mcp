{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ComparabilityQualification.v1.schema.json",
  "title": "ComparabilityQualification.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "comparabilityQualificationId",
    "podRef",
    "internalExposureRef",
    "routeMatch",
    "timeBasisMatch",
    "matrixMatch",
    "bindingBasisMatch",
    "populationMatch",
    "compartmentMatch",
    "qualificationStatus",
    "mismatchReasons",
    "policyProfileRef",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "requiredReviewState",
    "notARiskConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ComparabilityQualification.v1.schema.json"
    },
    "comparabilityQualificationId": {
      "type": "string",
      "minLength": 1
    },
    "podRef": {
      "type": "string",
      "minLength": 1
    },
    "internalExposureRef": {
      "type": "string",
      "minLength": 1
    },
    "routeMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "timeBasisMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "matrixMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "bindingBasisMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "populationMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "compartmentMatch": {
      "enum": ["match", "partial", "mismatch", "not_assessed", "unknown_with_blocker"]
    },
    "qualificationStatus": {
      "enum": [
        "comparable",
        "comparable_with_limitations",
        "not_comparable",
        "review_required",
        "blocked",
        "not_assessed"
      ]
    },
    "mismatchReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policyProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredReviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "notARiskConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
