{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SusceptibilitySummary.v1.schema.json",
  "title": "SusceptibilitySummary.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "susceptibilitySummaryId",
    "subgroupRef",
    "comparisonRefs",
    "dominantDriverRefs",
    "conclusionClass",
    "supportLevel",
    "actionability",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "nonClaimBoundaryRefs",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "requiredReviewState",
    "limitations",
    "notIndividualRiskPrediction",
    "notFinalRiskConclusion",
    "notRegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/SusceptibilitySummary.v1.schema.json"
    },
    "susceptibilitySummaryId": {
      "type": "string",
      "minLength": 1
    },
    "subgroupRef": {
      "type": "string",
      "minLength": 1
    },
    "comparisonRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dominantDriverRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conclusionClass": {
      "enum": [
        "subgroup_modifier_context",
        "susceptibility_signal",
        "requires_review",
        "not_interpretable",
        "blocked",
        "not_assessed"
      ]
    },
    "supportLevel": {
      "enum": [
        "none",
        "weak",
        "moderate",
        "strong",
        "not_assessed"
      ]
    },
    "actionability": {
      "enum": [
        "none",
        "screening",
        "prioritization",
        "requires_review",
        "decision_support",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonClaimBoundaryRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredReviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notIndividualRiskPrediction": {
      "type": "boolean",
      "const": true
    },
    "notFinalRiskConclusion": {
      "type": "boolean",
      "const": true
    },
    "notRegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
