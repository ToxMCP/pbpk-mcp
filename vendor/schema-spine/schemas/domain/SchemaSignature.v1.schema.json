{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/SchemaSignature.v1.schema.json",
  "title": "SchemaSignature.v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "required": [
    "schemaId",
    "signatureId",
    "signedSchemaRef",
    "schemaDigest",
    "canonicalizationAlgorithm",
    "signatureAlgorithm",
    "signatureValueDigest",
    "signer",
    "keyRef",
    "verificationStatus",
    "verifiedAt",
    "trustScope",
    "releaseBlocking",
    "limitations",
    "notScientificValidation"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/SchemaSignature.v1.schema.json"
    },
    "signatureId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "signedSchemaRef": {
      "type": "string",
      "format": "uri"
    },
    "schemaDigest": {
      "$ref": "#/$defs/digest"
    },
    "canonicalizationAlgorithm": {
      "enum": [
        "sha256-json-stable-v1",
        "sha256-raw-bytes",
        "other",
        "not_assessed"
      ]
    },
    "signatureAlgorithm": {
      "enum": [
        "sha256",
        "sha256_ed25519",
        "sha256_sigstore",
        "other",
        "not_assessed"
      ]
    },
    "signatureValueDigest": {
      "$ref": "#/$defs/digest"
    },
    "signer": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "keyRef": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "verificationStatus": {
      "enum": [
        "verified",
        "unverified",
        "failed",
        "expired",
        "not_assessed"
      ]
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "trustScope": {
      "enum": [
        "local_development",
        "internal_release",
        "public_release",
        "not_assessed"
      ]
    },
    "releaseBlocking": {
      "type": "boolean"
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "notScientificValidation": {
      "type": "boolean",
      "const": true
    }
  }
}
