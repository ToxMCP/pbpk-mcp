{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ModifierEvidenceLane.v1.schema.json",
  "title": "ModifierEvidenceLane.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "modifierEvidenceLaneId",
    "laneType",
    "evidenceRefs",
    "evidenceStrength",
    "dependenceAssessment",
    "reviewState",
    "uncertaintyRefs",
    "confidenceCeilingRefs",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "limitations",
    "notIndividualRiskPrediction"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ModifierEvidenceLane.v1.schema.json"
    },
    "modifierEvidenceLaneId": {
      "type": "string",
      "minLength": 1
    },
    "laneType": {
      "enum": [
        "exposure",
        "tk",
        "td",
        "clinical",
        "omics",
        "aop_context",
        "biomonitoring",
        "literature",
        "sensitive_descriptor_context",
        "not_assessed"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceStrength": {
      "enum": [
        "none",
        "weak",
        "moderate",
        "strong",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "dependenceAssessment": {
      "enum": [
        "independent",
        "partially_dependent",
        "dependent",
        "not_assessed"
      ]
    },
    "reviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceCeilingRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notIndividualRiskPrediction": {
      "type": "boolean",
      "const": true
    }
  }
}
