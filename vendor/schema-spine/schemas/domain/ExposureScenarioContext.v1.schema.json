{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ExposureScenarioContext.v1.schema.json",
  "title": "ExposureScenarioContext.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "exposureScenarioContextId",
    "chemicalRef",
    "route",
    "pathway",
    "population",
    "lifestage",
    "geography",
    "duration",
    "frequency",
    "averagingTime",
    "scenarioSourceRefs",
    "assumptionRefs",
    "uncertaintyRefs",
    "limitations",
    "notAnInternalDoseConclusion",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ExposureScenarioContext.v1.schema.json"
    },
    "exposureScenarioContextId": {
      "type": "string",
      "minLength": 1
    },
    "chemicalRef": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "aggregate",
        "not_assessed"
      ]
    },
    "pathway": {
      "type": "string",
      "minLength": 1
    },
    "population": {
      "type": "string",
      "minLength": 1
    },
    "lifestage": {
      "type": "string",
      "minLength": 1
    },
    "geography": {
      "type": "string",
      "minLength": 1
    },
    "duration": {
      "type": "string",
      "minLength": 1
    },
    "frequency": {
      "type": "string",
      "minLength": 1
    },
    "averagingTime": {
      "type": "string",
      "minLength": 1
    },
    "scenarioSourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptionRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "uncertaintyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notAnInternalDoseConclusion": {
      "type": "boolean",
      "const": true
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
