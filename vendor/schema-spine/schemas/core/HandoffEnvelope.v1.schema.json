{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/HandoffEnvelope.v1.schema.json",
  "title": "HandoffEnvelope.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "handoffId",
    "producer",
    "consumer",
    "objectRefs",
    "schemaPins",
    "compatibility",
    "acceptedClaims",
    "rejectedClaims",
    "downstreamUsePolicy"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/HandoffEnvelope.v1.schema.json"
    },
    "handoffId": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "consumer": {
      "type": "string",
      "minLength": 1
    },
    "objectRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "schemaPins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaId", "schemaDigest"],
        "properties": {
          "schemaId": {
            "type": "string",
            "format": "uri"
          },
          "schemaDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "compatibility": {
      "enum": [
        "accepted",
        "accepted_with_limitations",
        "rejected",
        "migration_required",
        "not_assessed"
      ]
    },
    "acceptedClaims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rejectedClaims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "downstreamUsePolicy": {
      "$ref": "https://schemas.ngra.ai/toxmcp/ClaimTransitionPolicy.v1.schema.json"
    }
  }
}
