{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/AuditTraceRef.v1.schema.json",
  "title": "AuditTraceRef.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "auditTraceId",
    "runId",
    "toolCallId",
    "requestHash",
    "responseHash",
    "schemaDigest",
    "chainHash"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/AuditTraceRef.v1.schema.json"
    },
    "auditTraceId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "toolCallId": {
      "type": "string",
      "minLength": 1
    },
    "requestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "responseHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "chainHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
