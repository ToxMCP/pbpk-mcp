{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ProvenanceBundle.v1.schema.json",
  "title": "ProvenanceBundle.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "provenanceId",
    "sources",
    "transforms",
    "agents",
    "citations",
    "licensePolicy"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ProvenanceBundle.v1.schema.json"
    },
    "provenanceId": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceId",
          "sourceName",
          "sourceType",
          "sourceVersion",
          "retrievedAt",
          "license",
          "contentDigest"
        ],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "sourceName": {
            "type": "string",
            "minLength": 1
          },
          "sourceType": {
            "enum": [
              "dataset",
              "api",
              "literature",
              "model",
              "mcp",
              "human",
              "other"
            ]
          },
          "sourceVersion": {
            "type": "string",
            "minLength": 1
          },
          "retrievedAt": {
            "type": "string",
            "format": "date-time"
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "contentDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "transforms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transformId", "name", "version", "inputDigest", "outputDigest"],
        "properties": {
          "transformId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "inputDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "outputDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agentId", "agentType", "name", "version", "role"],
        "properties": {
          "agentId": {
            "type": "string",
            "minLength": 1
          },
          "agentType": {
            "enum": [
              "human",
              "ai_model",
              "deterministic_tool",
              "mcp_server"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citationId", "label"],
        "properties": {
          "citationId": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "doi": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "licensePolicy": {
      "enum": [
        "open",
        "restricted",
        "tenant_restricted",
        "internal_only",
        "unknown_with_blocker"
      ]
    }
  }
}
