{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/DataRightsPolicy.v1.schema.json",
  "title": "DataRightsPolicy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "dataRightsPolicyId",
    "sourceRefs",
    "licenseProfile",
    "redistributionAllowed",
    "publicUseAllowed",
    "rawPayloadRetention",
    "dataMinimizationApplied",
    "clearanceStatus"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/DataRightsPolicy.v1.schema.json"
    },
    "dataRightsPolicyId": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "licenseProfile": {
      "enum": [
        "open",
        "restricted",
        "tenant_restricted",
        "internal_only",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "redistributionAllowed": {
      "type": "boolean"
    },
    "publicUseAllowed": {
      "type": "boolean"
    },
    "rawPayloadRetention": {
      "enum": [
        "retained",
        "redacted_with_digest",
        "not_retained_with_reason"
      ]
    },
    "dataMinimizationApplied": {
      "type": "boolean"
    },
    "clearanceStatus": {
      "enum": [
        "cleared",
        "restricted",
        "not_assessed",
        "unknown_with_blocker"
      ]
    }
  }
}
