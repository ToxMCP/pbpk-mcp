{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/DecisionContext.v1.schema.json",
  "title": "DecisionContext.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "contextId",
    "intendedUse",
    "endpointScope",
    "route",
    "population",
    "jurisdictionHints",
    "regulatoryUseScenario",
    "outOfScopeBoundaries"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/DecisionContext.v1.schema.json"
    },
    "contextId": {
      "type": "string",
      "minLength": 1
    },
    "intendedUse": {
      "type": "string",
      "minLength": 1
    },
    "endpointScope": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "in_vitro",
        "aggregate",
        "not_applicable",
        "not_assessed"
      ]
    },
    "population": {
      "type": "string",
      "minLength": 1
    },
    "jurisdictionHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "regulatoryUseScenario": {
      "type": "string",
      "minLength": 1
    },
    "outOfScopeBoundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
