{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/HumanReviewRecord.v1.schema.json",
  "title": "HumanReviewRecord.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "reviewId",
    "reviewerRole",
    "reviewStage",
    "blindedState",
    "conflictDeclaration",
    "decision",
    "reviewedAt"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/HumanReviewRecord.v1.schema.json"
    },
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "reviewerRole": {
      "enum": [
        "toxicologist",
        "risk_assessor",
        "data_engineer",
        "regulatory_expert",
        "qa_reviewer",
        "other"
      ]
    },
    "reviewStage": {
      "enum": [
        "screening",
        "blinded_challenge",
        "adjudication",
        "final_signoff",
        "waiver_review"
      ]
    },
    "blindedState": {
      "enum": [
        "blinded",
        "unblinded",
        "not_applicable"
      ]
    },
    "conflictDeclaration": {
      "enum": [
        "none",
        "declared",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "decision": {
      "enum": [
        "accepted",
        "corrected",
        "rejected",
        "waived",
        "review_required",
        "unknown_with_blocker"
      ]
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signatureRef": {
      "type": "string",
      "minLength": 1
    },
    "notesDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
