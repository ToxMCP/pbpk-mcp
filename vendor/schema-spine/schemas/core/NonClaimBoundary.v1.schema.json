{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/NonClaimBoundary.v1.schema.json",
  "title": "NonClaimBoundary.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "boundaryId",
    "prohibitedClaims",
    "requiredCaveats",
    "reviewerRequirement",
    "autonomousUseProhibition"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/NonClaimBoundary.v1.schema.json"
    },
    "boundaryId": {
      "type": "string",
      "minLength": 1
    },
    "prohibitedClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredCaveats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewerRequirement": {
      "enum": [
        "none",
        "human_review_required",
        "expert_review_required",
        "adjudication_required"
      ]
    },
    "autonomousUseProhibition": {
      "type": "boolean"
    }
  }
}
