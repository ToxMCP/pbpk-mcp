{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ClaimRecord.v1.schema.json",
  "title": "ClaimRecord.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "claimId",
    "claimText",
    "claimClass",
    "endpoint",
    "route",
    "timeBasis",
    "population",
    "decisionContextRef",
    "supportLevel",
    "actionability",
    "allowedDownstreamUses",
    "prohibitedDownstreamUses",
    "requiredReviewState",
    "notARegulatoryConclusion"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/ClaimRecord.v1.schema.json"
    },
    "claimId": {
      "type": "string",
      "minLength": 1
    },
    "claimText": {
      "type": "string",
      "minLength": 1
    },
    "claimClass": {
      "enum": [
        "identity",
        "context_only",
        "association",
        "bioactivity",
        "mechanistic_support",
        "causal_support",
        "adversity",
        "exposure",
        "internal_dose",
        "risk",
        "regulatory_translation",
        "not_assessed"
      ]
    },
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "oral",
        "inhalation",
        "dermal",
        "ocular",
        "in_vitro",
        "aggregate",
        "not_applicable",
        "not_assessed"
      ]
    },
    "timeBasis": {
      "type": "string",
      "minLength": 1
    },
    "population": {
      "type": "string",
      "minLength": 1
    },
    "jurisdictionContext": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionContextRef": {
      "type": "string",
      "minLength": 1
    },
    "supportLevel": {
      "enum": [
        "not_assessed",
        "context_only",
        "weak",
        "moderate",
        "strong",
        "conflicting",
        "insufficient",
        "unknown_with_blocker"
      ]
    },
    "actionability": {
      "enum": [
        "none",
        "screening",
        "prioritization",
        "requires_review",
        "decision_support",
        "not_assessed",
        "unknown_with_blocker"
      ]
    },
    "allowedDownstreamUses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedDownstreamUses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requiredReviewState": {
      "enum": [
        "machine_checked",
        "human_review_required",
        "human_reviewed",
        "adjudicated",
        "blocked",
        "not_assessed"
      ]
    },
    "notARegulatoryConclusion": {
      "type": "boolean",
      "const": true
    }
  }
}
