{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/ToxMcpObject.v1.schema.json",
  "title": "ToxMcpObject.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaDialect",
    "schemaFamily",
    "schemaMajor",
    "schemaVersion",
    "schemaDigest",
    "packageVersion",
    "objectId",
    "objectType",
    "createdAt",
    "createdBy",
    "provenance",
    "assessmentRunRef",
    "audit",
    "reviewState",
    "nonClaimBoundaries",
    "limitations",
    "knownDataGaps"
  ],
  "properties": {
    "schemaId": {
      "type": "string",
      "format": "uri"
    },
    "schemaDialect": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "schemaFamily": {
      "type": "string",
      "minLength": 1
    },
    "schemaMajor": {
      "type": "integer",
      "const": 1
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "schemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "packageVersion": {
      "type": "string",
      "minLength": 1
    },
    "domainModuleVersion": {
      "type": "string",
      "minLength": 1
    },
    "migrationStatus": {
      "enum": [
        "native",
        "migrated",
        "migration_required",
        "unknown_major_blocked",
        "not_assessed"
      ]
    },
    "objectId": {
      "type": "string",
      "minLength": 1
    },
    "objectType": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mcp", "tool", "toolVersion"],
      "properties": {
        "mcp": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "toolVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "$ref": "https://schemas.ngra.ai/toxmcp/ProvenanceBundle.v1.schema.json"
    },
    "assessmentRunRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit": {
      "$ref": "https://schemas.ngra.ai/toxmcp/AuditTraceRef.v1.schema.json"
    },
    "reviewState": {
      "$ref": "https://schemas.ngra.ai/toxmcp/ReviewState.v1.schema.json"
    },
    "nonClaimBoundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://schemas.ngra.ai/toxmcp/NonClaimBoundary.v1.schema.json"
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "knownDataGaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
