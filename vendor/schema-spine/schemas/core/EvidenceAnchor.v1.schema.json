{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ngra.ai/toxmcp/EvidenceAnchor.v1.schema.json",
  "title": "EvidenceAnchor.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "evidenceAnchorId",
    "claimRef",
    "evidenceClass",
    "role",
    "supportDirection",
    "targetEntity",
    "limitations",
    "sourceObjectRefs"
  ],
  "properties": {
    "schemaId": {
      "const": "https://schemas.ngra.ai/toxmcp/EvidenceAnchor.v1.schema.json"
    },
    "evidenceAnchorId": {
      "type": "string",
      "minLength": 1
    },
    "claimRef": {
      "type": "string",
      "minLength": 1
    },
    "evidenceClass": {
      "enum": [
        "chemical_identity",
        "in_vitro_bioactivity",
        "omics",
        "aop",
        "exposure",
        "pbpk",
        "ivive",
        "literature",
        "regulatory_context",
        "population_variability",
        "mixture",
        "not_assessed"
      ]
    },
    "role": {
      "enum": [
        "primary",
        "supporting",
        "contradictory",
        "context",
        "quality_control",
        "not_assessed"
      ]
    },
    "supportDirection": {
      "enum": [
        "supports",
        "weakly_supports",
        "contradicts",
        "mixed",
        "context_only",
        "not_assessed"
      ]
    },
    "targetEntity": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceObjectRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
